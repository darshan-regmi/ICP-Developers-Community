# ──────────────────────────────────────────────────────────────────────────
# ICP Developers' Community — environment template
#
# Copy this file to `.env.local` and fill in real values:
#     cp .env.example .env.local
#
# .env.local is gitignored. Never commit a file containing real keys.
# For production, the same variables go in the Vercel project's
# Settings → Environment Variables.
# ──────────────────────────────────────────────────────────────────────────


# ─── REQUIRED ─────────────────────────────────────────────────────────────

# Your Resend API key.
# Sign up at https://resend.com → API Keys → Create API Key.
# Without this, the application forms return "Email service is not configured."
RESEND_API_KEY=


# ─── OPTIONAL ─────────────────────────────────────────────────────────────

# Resend Audience ID. Enables duplicate-submission detection.
#   1. https://resend.com/audiences → Create Audience (e.g. "ICP DC Applicants")
#   2. Copy the audience ID from the URL bar or the audience page
#   3. Paste below + add the same value to Vercel env vars
# Without this, the form still works but does NOT deduplicate repeat applicants
# (you'll see `[apply] RESEND_AUDIENCE_ID not set` in server logs).
RESEND_AUDIENCE_ID=

# Override the "from" address on all outbound emails.
# Default: "ICP DC <onboarding@resend.dev>" (Resend's shared test sender).
# For production, verify a domain in Resend → Domains and switch this:
#   RESEND_FROM="ICP DC <apply@icp-dc.com>"
RESEND_FROM=

# Override the admin inbox where applications are delivered.
# Default: dev@icp.edu.np
APPLY_TO_EMAIL=


# ─── BOT / SPAM PROTECTION ────────────────────────────────────────────────

# hCaptcha keys. Sign up free at https://www.hcaptcha.com/ → Sites → Add Site,
# then copy the Site Key (public) and Secret Key (server-side).
#
# Both must be set together. If either is empty, captcha verification is
# skipped server-side and the widget is hidden client-side — useful in local
# dev but DO NOT deploy without these set in production.
#
# Use these test keys in local dev to bypass real challenges:
#   NEXT_PUBLIC_HCAPTCHA_SITE_KEY=10000000-ffff-ffff-ffff-000000000001
#   HCAPTCHA_SECRET_KEY=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET_KEY=
